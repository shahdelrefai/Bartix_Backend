{
  "ConnectionStrings": {
    "Database": ""
  },
  "Authentication": {
    "Jwt": {
      "Issuer": "Bartrix.Api",
      "Audience": "Bartrix.Mobile",
      "SigningKey": "replace-with-a-long-random-secret-key",
      "AccessTokenMinutes": 15,
      "ClockSkewSeconds": 60
    },
    "RefreshTokens": {
      "ExpiryDays": 30,
      "TokenLengthBytes": 64
    },
    "Otp": {
      "Provider": "LocalMock",
      "CodeLength": 6,
      "ExpiryMinutes": 10,
      "MaxAttempts": 5,
      "DevelopmentCode": "123456"
    }
  },
  "Storage": {
    "S3": {
      "BucketName": "bartrix-media",
      "Region": "us-east-1",
      "AccessKey": "",
      "SecretKey": "",
      "ServiceUrl": "",
      "ForcePathStyle": false,
      "CreateBucketIfMissing": false
    }
  },
  "Realtime": {
    "SignalR": {
      "EnableDetailedErrors": false
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
