{
  "ConnectionStrings": {
    "Database": ""
  },
  "Authentication": {
    "Jwt": {
      "Issuer": "Bartrix.Api",
      "Audience": "Bartrix.Mobile",
      "SigningKey": "replace-with-a-long-random-secret-key",
      "AccessTokenMinutes": 15,
      "ClockSkewSeconds": 60
    },
    "RefreshTokens": {
      "ExpiryDays": 30,
      "TokenLengthBytes": 64
    },
    "Otp": {
      "Provider": "LocalMock",
      "CodeLength": 6,
      "ExpiryMinutes": 10,
      "MaxAttempts": 5,
      "DevelopmentCode": "123456"
    }
  },
  "Storage": {
    "Minio": {
      "Endpoint": "localhost:9000",
      "AccessKey": "minioadmin",
      "SecretKey": "minioadmin",
      "BucketName": "bartrix-media",
      "UseSsl": false,
      "CreateBucketIfMissing": false
    }
  },
  "Realtime": {
    "SignalR": {
      "EnableDetailedErrors": false
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
